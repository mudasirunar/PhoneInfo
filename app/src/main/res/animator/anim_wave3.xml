<?xml version="1.0" encoding="utf-8"?>
<objectAnimator xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="1100"
    android:startOffset="1200"
    android:repeatCount="infinite"
    android:repeatMode="restart">
    <propertyValuesHolder android:propertyName="trimPathEnd">
        <keyframe android:fraction="0.0"  android:value="0.0"/>
        <keyframe android:fraction="0.45" android:value="1.0"
            android:interpolator="@android:interpolator/accelerate_decelerate"/>
        <keyframe android:fraction="0.75" android:value="1.0"/>
        <keyframe android:fraction="1.0"  android:value="0.0"
            android:interpolator="@android:interpolator/decelerate_quad"/>
    </propertyValuesHolder>
</objectAnimator>