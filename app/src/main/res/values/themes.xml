<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PhoneInfo" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation duration. -->
        <item name="windowSplashScreenBackground">#0A0A1E</item>
        <!-- Use windowSplashScreenAnimatedIcon to add either a drawable or an animated drawable -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_animated</item>
        <item name="windowSplashScreenAnimationDuration">3600</item>
        <!-- Set the theme of the Activity that directly follows your splash screen. -->
        <item name="postSplashScreenTheme">@style/Theme.PhoneInfo</item>
    </style>

</resources>